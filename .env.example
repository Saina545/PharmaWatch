# ─── Copy this file to .env and fill in real values ───────────────────────

# ── PostgreSQL / Supabase ─────────────────────────────────────────────────
# For local Docker: jdbc:postgresql://localhost:5432/pharmawatch
# For Supabase:     jdbc:postgresql://db.<project>.supabase.co:5432/postgres
DATABASE_URL=jdbc:postgresql://localhost:5432/pharmawatch
DATABASE_USERNAME=pharmawatch_user
DATABASE_PASSWORD=your_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate a random 64-char string: openssl rand -base64 48
JWT_SECRET=replace-with-a-very-long-random-secret-key-at-least-256-bits

# ── Email (Gmail App Password) ─────────────────────────────────────────────
# Create an App Password at https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── AI Engine ─────────────────────────────────────────────────────────────
# Get free API key at https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_api_key_here
# Optional PubMed key (increases rate limit)
PUBMED_API_KEY=your_pubmed_api_key_here
